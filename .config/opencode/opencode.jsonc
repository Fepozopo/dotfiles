{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "github-copilot/gpt-5-mini",
  "default_agent": "build",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "bash": {
      "git *": "ask"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "git *": "ask"
        }
      }
    }
  }
}
